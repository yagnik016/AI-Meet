{
  "version": 2,
  "builds": [
    {
      "src": "src/main.vercel.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.vercel.ts"
    }
  ],
  "buildCommand": "prisma generate && tsc -p tsconfig.json",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  }
}
